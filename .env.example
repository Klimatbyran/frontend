# Client ID for GitHub OAuth app
VITE_GITHUB_CLIENT_ID=

# Unearth API for local dev (Vite proxies /api → this origin). Default: http://localhost:3000/
VITE_API_PROXY=https://api.unearthdata.ai/

# OpenAPI schema for `npm run generate-api` (optional; default is production /reference/openapi.json)
# OPENAPI_SCHEMA_URL=https://stage-api.unearthdata.ai/reference/openapi.json

# Site origin for absolute URLs (canonical, OpenGraph, etc.)
VITE_SITE_ORIGIN=https://klimatkollen.se

# API key sent as X-API-Key on proxied /api requests (from `npm run seed:client-api` in garbo)
GARBO_ALL_ACCESS_API_KEY=

# Publishable API key for logo.dev
VITE_LOGO_DEV_PUBLISHABLE_KEY=
