{
  "name": "klimatkollen",
  "private": true,
  "version": "8.1.2-rc.22",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev-gen": "npm run generate-api && vite",
    "prebuild": "npm run build:dataguide",
    "build": "tsc && vite build",
    "build:dataguide": "node scripts/build-dataguide.js",
    "postbuild": "npm run generate-sitemap || echo 'Sitemap generation failed, but build completed' && tsx scripts/generate-report-html.ts",
    "lint": "eslint .",
    "test": "vitest",
    "preview": "vite preview",
    "generate-report-html": "tsx scripts/generate-report-html.ts",
    "generate-api": "node scripts/generate-api.js",
    "generate-api:staging": "node scripts/generate-api.js https://stage-api.unearthdata.ai/reference/openapi.json",
    "format": "npm run lint -- --fix; npx prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format-prettier": "npx prettier --write \"src/**/*.{ts,tsx,json}\"",
    "format-lint": "npm run lint -- --fix",
    "generate-api:local": "node scripts/generate-api.js http://localhost:3000/reference/openapi.json",
    "generate-sitemap": "NODE_OPTIONS='--no-warnings' tsx scripts/generate-sitemap.ts || echo 'Sitemap generation failed, continuing build'",
    "check-unused-components": "tsx scripts/check-unused-components.ts",
    "prepare": "husky"
  },
  "dependencies": {
    "@fontsource/dm-sans": "^5.2.5",
    "@hookform/resolvers": "^3.9.0",
    "@radix-ui/react-accordion": "^1.2.0",
